    "eslint-plugin-vue": "~10.9.2",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^9.0.1",
    "oxfmt": "^0.54.0",
    "oxlint": "~1.69.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.2.6"
